# Shell scripts must use LF so they run on the Linux server host.
*.sh text eol=lf

# git-crypt: encrypt credential files under .credential/, but keep the
# documentation and attribute files themselves in plaintext.
/.credential/** filter=git-crypt diff=git-crypt
/.credential/README.txt !filter !diff
/.credential/README.md !filter !diff
/.credential/README.cn.md !filter !diff
/.credential/.gitattributes !filter !diff
.gitattributes !filter !diff
