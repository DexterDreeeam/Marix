{
  "schemaVersion": 1,
  "module": {
    "path": "src/protocol",
    "name": "protocol",
    "purpose": "Defines serialized workflow contracts whose actor events carry typed result statuses directly, including ExecutionResult and ExecutionResultKind outcomes.",
    "changeStatus": "modified"
  },
  "modified": ["lib.rs", "mod.rs"],
  "childModules": [
    {
      "path": "src/protocol/execution",
      "name": "execution",
      "purpose": "Defines execution requests, identities, signatures, errors, cancellation events, and typed ExecutionResult and ExecutionResultKind outcomes."
    },
    {
      "path": "src/protocol/executor",
      "name": "executor",
      "purpose": "Owns executor-level protocol events that wrap host execution lifecycle requests, nested execution events, status updates, and cancellation."
    },
    {
      "path": "src/protocol/external",
      "name": "external",
      "purpose": "Local protocol crate wiring that re-exports serde derive macros, serde_json, and uuid for protocol internals; it has no selectable protocol elements."
    },
    {
      "path": "src/protocol/intent",
      "name": "intent",
      "purpose": "Defines intent contexts, identities, signatures, results, and drafts; IntentEvent carries typed plan, step, and relay result statuses, while IntentVerdict accepts complete, plan, tool_calls, and infeasible wire decisions."
    },
    {
      "path": "src/protocol/invocation",
      "name": "invocation",
      "purpose": "Defines invocation drafts, requests, identities, signatures, errors, results, and events whose execution updates carry ActorStatus<ExecutionResult> directly."
    },
    {
      "path": "src/protocol/plan",
      "name": "plan",
      "purpose": "Defines plan contexts, identities, signatures, results, and drafts; PlanEvent carries typed intent and relay result statuses, and PlanVerdict supports replacement and infeasible decisions."
    },
    {
      "path": "src/protocol/relay",
      "name": "relay",
      "purpose": "Defines prompt-only relay requests and intent-scoped signatures that optionally identify a plan, plus identities, errors, cancellation events, and typed terminal model results."
    },
    {
      "path": "src/protocol/session",
      "name": "session",
      "purpose": "Owns the top-level SessionEvent envelope, including optional UUID correlation metadata and task/executor traffic."
    },
    {
      "path": "src/protocol/step",
      "name": "step",
      "purpose": "Defines invocation-based step drafts, identities, signatures, errors, and results; StepEvent carries ActorStatus<InvocationResult>, and StepResult contains a result kind and structured tool-call results."
    },
    {
      "path": "src/protocol/task",
      "name": "task",
      "purpose": "Defines task requests, previews, typed results, external transport statuses, identities, signatures, errors, and events whose root updates carry ActorStatus<IntentResult>."
    },
    {
      "path": "src/protocol/tool",
      "name": "tool",
      "purpose": "Defines string-backed tool input/output schema aliases and input-only tool previews with JSON conversion helpers."
    }
  ],
