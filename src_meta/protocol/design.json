{
  "schemaVersion": 1,
  "module": {
    "path": "src/protocol",
    "name": "protocol",
    "purpose": "Defines serialized workflow contracts with an independent execution lifecycle, result-carrying invocation and relay completion states, invocation output counts based on distinct Processing sequences, explicit intent starts, cancellation, and actor signatures.",
    "changeStatus": "modified"
  },
  "modified": [".", "lib.rs", "mod.rs"],
  "childModules": [
    {
      "path": "src/protocol/execution",
      "name": "execution",
      "purpose": "Defines execution requests, identities, signatures, errors, events, and an independent host-execution lifecycle."
    },
    {
      "path": "src/protocol/executor",
      "name": "executor",
      "purpose": "Owns executor-level protocol events that wrap host execution lifecycle requests, nested execution events, status updates, and cancellation."
    },
    {
      "path": "src/protocol/external",
      "name": "external",
      "purpose": "Local protocol crate wiring that re-exports serde derive macros, serde_json, and uuid for protocol internals; it has no selectable protocol elements."
    },
    {
      "path": "src/protocol/intent",
      "name": "intent",
      "purpose": "Defines intent drafts, verdicts, ResultKind-classified terminal results, identities, lineage-aware signatures, a Created/Running/Complete lifecycle whose Complete status carries the result, errors, child plan/step/relay updates, and cancellation."
    },
    {
      "path": "src/protocol/invocation",
      "name": "invocation",
      "purpose": "Defines invocation drafts and requests, identities, signatures, errors, managed execution events, terminal result kinds and payloads with output and distinct Processing sequence counts, and a Created/Running/Complete lifecycle."
    },
    {
      "path": "src/protocol/plan",
      "name": "plan",
      "purpose": "Defines nested plan drafts, verdicts, ResultKind-classified terminal results, identities, boxed owning-intent signatures, a Created/Running/Complete lifecycle whose Complete status carries the result, errors, child-intent and relay updates, and cancellation."
    },
    {
      "path": "src/protocol/relay",
      "name": "relay",
      "purpose": "Defines relay requests, identities, signatures, errors, cancellation events, terminal result kinds and payloads, and a Created/Running/Complete lifecycle for model output."
    },
    {
      "path": "src/protocol/session",
      "name": "session",
      "purpose": "Owns the top-level SessionEvent envelope, including optional UUID correlation metadata and task/executor traffic."
    },
    {
      "path": "src/protocol/step",
      "name": "step",
      "purpose": "Defines invocation-based step drafts, identities, signatures, a Created/Running/Complete lifecycle carrying ResultKind-classified Succeed/Canceled/Failed results, errors, direct invocation updates, and cancellation."
    },
    {
      "path": "src/protocol/task",
      "name": "task",
      "purpose": "Defines task requests, results, identities, signatures, statuses, errors, actor event envelopes with explicit intent starts, terminal updates, and cancellation."
    },
    {
      "path": "src/protocol/tool",
      "name": "tool",
      "purpose": "Defines string-backed tool input/output schema aliases and input-only tool previews with JSON conversion helpers."
    }
  ],
