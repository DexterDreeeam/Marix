{
  "schemaVersion": 1,
  "module": {
    "path": "src/protocol",
    "name": "protocol",
    "purpose": "Defines serialized context-chain contracts for intent planning and task execution, plus relay, step, invocation, execution, session, categorized tools, and workflow decisions.",
    "changeStatus": "modified"
  },
  "childModules": [
    {
      "path": "src/protocol/execution",
      "name": "execution",
      "purpose": "Defines execution requests, identities, signatures, errors, cancellation events, and typed ExecutionResult and ExecutionResultKind outcomes."
    },
    {
      "path": "src/protocol/executor",
      "name": "executor",
      "purpose": "Owns executor-level protocol events that wrap host execution lifecycle requests, nested execution events, status updates, and cancellation."
    },
    {
      "path": "src/protocol/external",
      "name": "external",
      "purpose": "Local protocol crate wiring that re-exports serde derive macros, serde_json, and uuid for protocol internals; it has no selectable protocol elements."
    },
    {
      "path": "src/protocol/intent",
      "name": "intent",
      "purpose": "Defines intent contexts with ordered step results, subintent signatures, and prior plan failures, plus signatures, lifecycle events, terminal results, and plan contracts; IntentVerdict parses plan, complete, and infeasible decisions."
    },
    {
      "path": "src/protocol/invocation",
      "name": "invocation",
      "purpose": "Defines invocation drafts, requests, identities, signatures, errors, results, and events whose execution updates carry ActorStatus<ExecutionResult> directly."
    },
    {
      "path": "src/protocol/relay",
      "name": "relay",
      "purpose": "Defines prompt-only relay requests and intent-owned signatures, plus identities, errors, cancellation events, and terminal model results."
    },
    {
      "path": "src/protocol/session",
      "name": "session",
      "purpose": "Owns SessionEvent, whose ExecutorTools variant carries a concrete System together with a vector of ToolPreview values."
    },
    {
      "path": "src/protocol/step",
      "name": "step",
      "purpose": "Defines invocation-based step drafts with strict JSON parsing, identities, signatures, errors, and results; StepEvent carries ActorStatus<InvocationResult>, and StepResult contains structured tool-call results."
    },
    {
      "path": "src/protocol/task",
      "name": "task",
      "purpose": "Defines task requests, previews, terminal results, transport statuses, identities, signatures, errors, and events for intent, step, invocation, and relay routing."
    },
    {
      "path": "src/protocol/tool",
      "name": "tool",
      "purpose": "Defines file, shell, system, and workflow tool categories, string-backed schema aliases, and JSON-convertible tool previews carrying category and target-system metadata."
    },
    {
      "path": "src/protocol/workflow",
      "name": "workflow",
      "purpose": "Defines workflow decision-tool contracts and complete, plan, and infeasible payloads with previews and JSON parsing."
    }
  ],
