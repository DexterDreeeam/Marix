{
  "schemaVersion": 1,
  "module": {
    "path": "src/protocol",
    "name": "protocol",
    "purpose": "Owns marix-protocol crate definitions and namespace exports for hierarchical session, task, plan, step, invocation, executor, relay, host execution, tool, and shared signature/status/error contracts.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/protocol/execution",
      "name": "execution",
      "purpose": "Owns host execution protocol contracts for real host-side execution: execution requests, execution ids, signatures, statuses, and the cancellation event shape."
    },
    {
      "path": "src/protocol/executor",
      "name": "executor",
      "purpose": "Owns executor-level protocol events that wrap host execution lifecycle requests, nested execution events, status updates, and cancellation."
    },
    {
      "path": "src/protocol/external",
      "name": "external",
      "purpose": "Owns the external source module."
    },
    {
      "path": "src/protocol/invocation",
      "name": "invocation",
      "purpose": "Owns server-side invocation protocol contracts: invocation ids, signatures, requests, statuses, and events that carry host execution events without host execution signatures."
    },
    {
      "path": "src/protocol/plan",
      "name": "plan",
      "purpose": "Owns plan protocol contracts including plan identity/signatures, plan drafts, plan events that nest step events, plan status updates, and model answer payloads."
    },
    {
      "path": "src/protocol/relay",
      "name": "relay",
      "purpose": "Owns relay protocol contracts including relay identity/signatures, requests, statuses, and the relay cancellation event shape."
    },
    {
      "path": "src/protocol/session",
      "name": "session",
      "purpose": "Owns the SessionEvent protocol enum for top-level task creation, task updates, and nested task events."
    },
    {
      "path": "src/protocol/step",
      "name": "step",
      "purpose": "Owns step protocol contracts including step identity/signatures, step drafts/kinds, previews/results, and step events that nest invocation and relay events."
    },
    {
      "path": "src/protocol/task",
      "name": "task",
      "purpose": "Owns task protocol contracts including task identity/signatures, task requests, task previews/results, task status, and task events that nest plan events."
    },
    {
      "path": "src/protocol/tool",
      "name": "tool",
      "purpose": "Owns the tool source module."
    }
  ],
