{
  "schemaVersion": 1,
  "module": {
    "path": "src/protocol",
    "name": "protocol",
    "purpose": "Owns marix-protocol crate definitions and namespace exports for hierarchical session, task, plan, step, invocation, executor, relay, host execution, tool, and shared signature/status/error contracts.",
    "changeStatus": "modified"
  },
  "modified": [
    "."
  ],
  "childModules": [
    {
      "path": "src/protocol/execution",
      "name": "execution",
      "purpose": "Owns host execution protocol contracts: execution requests, ids, signatures, statuses, errors, and cancellation events."
    },
    {
      "path": "src/protocol/executor",
      "name": "executor",
      "purpose": "Owns executor-level protocol events that wrap host execution lifecycle requests, nested execution events, status updates, and cancellation."
    },
    {
      "path": "src/protocol/external",
      "name": "external",
      "purpose": "Local protocol crate wiring that re-exports serde derive macros, serde_json, and uuid for protocol internals; it has no selectable protocol elements."
    },
    {
      "path": "src/protocol/invocation",
      "name": "invocation",
      "purpose": "Owns server-side invocation protocol contracts: invocation ids, signatures, requests, statuses, errors, and events that carry host execution events without host execution signatures."
    },
    {
      "path": "src/protocol/plan",
      "name": "plan",
      "purpose": "Owns plan protocol contracts including plan identity/signatures, plan drafts, plan events that carry step status updates, plan statuses, errors, and model answer payloads."
    },
    {
      "path": "src/protocol/relay",
      "name": "relay",
      "purpose": "Owns relay protocol contracts including relay identity/signatures, requests, statuses, errors, and relay cancellation events."
    },
    {
      "path": "src/protocol/session",
      "name": "session",
      "purpose": "Owns the SessionEvent protocol enum for top-level task creation, task updates, and nested task events."
    },
    {
      "path": "src/protocol/step",
      "name": "step",
      "purpose": "Owns step protocol contracts including step identity/signatures, step drafts/kinds, previews/results, step statuses, and step events that nest invocation and relay events."
    },
    {
      "path": "src/protocol/task",
      "name": "task",
      "purpose": "Owns task protocol contracts including task identity/signatures, task requests, previews/results, task status, task errors, and task events that nest plan events."
    },
    {
      "path": "src/protocol/tool",
      "name": "tool",
      "purpose": "Owns tool protocol metadata contracts split into ToolSchema, ToolInputSchema, ToolOutputSchema, and ToolPreview models with JSON conversion helpers."
    }
  ],
