{
  "schemaVersion": 1,
  "module": {
    "path": "src/common",
    "name": "common",
    "purpose": "Shared common crate root for reusable config loading with default CoreConfig fallback, server IP and handshake token resolution from plain config values, external re-export adapters, database telemetry logging, and structure utilities. It exposes WorkQueue cleanup support used by server host-disconnect session reset, and lib.rs re-exports serializable config system types Arch, Platform, and System alongside Config, ServerConfig, and related models, plus the Logger telemetry client with LogMessage, LogTag, and LoggingError.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/common/config",
      "name": "config",
      "purpose": "Owns the common crate configuration model, config-file discovery, serializable OS/architecture System detection, the model API key, server IP, and server handshake auth token as plain config values, a replaceable config cache with Config::load and test-only Config::mock overrides, runtime path normalization, default CoreConfig fallback, client settings without endpoint addresses, server runtime IP, handshake token, and port settings, and tool directory settings."
    },
    {
      "path": "src/common/external",
      "name": "external",
      "purpose": "Owns public re-export wrappers for third-party libraries so downstream crates can route third-party access through common where appropriate, including the redb embedded-database wrapper backing telemetry storage."
    },
    {
      "path": "src/common/logging",
      "name": "logging",
      "purpose": "Owns the database telemetry logging system: the serializable LogTag and LogMessage records, the LoggingError enum, and the Logger client that hosts a telemetry server accepting authenticated remoc channel connections and persisting messages to a fresh per-start timestamped local redb database, or connects to a remote server and streams LogMessage records over the authenticated channel transport."
    },
    {
      "path": "src/common/structure",
      "name": "structure",
      "purpose": "Owns shared structural data interfaces such as WorkQueue, whose clear() method empties working and completed entries for session cleanup, plus channel helpers: accept_channel binds the listener once and accepts in a loop until one connection passes the shared-secret handshake within a 5-second per-connection timeout, while connect_channel makes a single attempt and surfaces ChannelError::Auth when the server rejects the token."
    }
  ],
