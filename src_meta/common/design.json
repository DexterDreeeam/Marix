    "path": "src/common",
    "name": "common",
    "purpose": "Owns shared configuration, third-party wrappers, source- and session-aware telemetry with persistent migration/query support, and reusable transport structures.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/common/config",
      "name": "config",
      "purpose": "Strongly typed TOML configuration models and loading, including separate telemetry transport and self-hosted HTTP page ports."
    },
    {
      "path": "src/common/external",
      "name": "external",
      "purpose": "Re-exports approved third-party namespaces and traits for common, including UUID generation and redb read/query support."
    },
    {
      "path": "src/common/logging",
      "name": "logging",
      "purpose": "Owns source- and session-aware process telemetry, configurable local or authenticated remote sinks, fixed-database legacy migration, and reverse-chronological session queries."
    },
    {
      "path": "src/common/structure",
      "name": "structure",
      "purpose": "Owns shared channel and work-queue structures, including authenticated remoc transport, wildcard IPv4 server listeners, configured client endpoints, handshake timeouts, and reusable queue cleanup."
    }
