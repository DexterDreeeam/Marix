  "module": {
    "path": "src/tool/native",
    "name": "native",
    "purpose": "Groups built-in file, shell, system, coding, process, and web tools with shared native execution support; WebFetch cleans HTML into markdown-like text and web search providers use 60-second request limits.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/tool/native/file",
      "name": "file",
      "purpose": "Provides four filesystem tools whose File previews declare All/All wildcard compatibility, with compatible parsing for unescaped Windows path backslashes."
    },
    {
      "path": "src/tool/native/shell",
      "name": "shell",
      "purpose": "Provides Bash, Command Prompt, and PowerShell tools launched through absolute system paths, with shared JSON process execution and structured failures."
    },
    {
      "path": "src/tool/native/sys",
      "name": "sys",
      "purpose": "Provides OsEnv with a System-category All/All preview and a safe allowlisted environment report."
    },
    {
      "path": "src/tool/native/coding",
      "name": "coding",
      "purpose": "Native coding tool implementations."
    },
    {
      "path": "src/tool/native/process",
      "name": "process",
      "purpose": "Native process tool implementations."
    },
    {
      "path": "src/tool/native/web",
      "name": "web",
      "purpose": "Provides native web fetch and search tools; WebFetch converts HTML into clean markdown-like text with links, decoded entities, and suppressed non-content elements, while WebSearch queries DuckDuckGo, Yahoo, and Wikipedia with 60-second provider request limits."
    }
  ],
