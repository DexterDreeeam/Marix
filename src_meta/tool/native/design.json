    "path": "src/tool/native",
    "name": "native",
    "purpose": "Groups eight built-in tools and shared native execution support; shell tool descriptions remain limited to each shell's own syntax and path conventions.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/tool/native/file",
      "name": "file",
      "purpose": "Provides four filesystem tools whose File previews declare All/All wildcard compatibility, with compatible parsing for unescaped Windows path backslashes."
    },
    {
      "path": "src/tool/native/shell",
      "name": "shell",
      "purpose": "Provides Bash, Command Prompt, and PowerShell tools whose descriptions state only each shell's own syntax and path conventions, plus shared process execution."
    },
    {
      "path": "src/tool/native/sys",
      "name": "sys",
      "purpose": "Provides OsEnv with a System-category All/All preview and a safe allowlisted environment report."
    }
