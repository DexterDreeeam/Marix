{
  "schemaVersion": 1,
  "module": {
    "path": "src/server/model",
    "name": "model",
    "purpose": "Defines the streaming-only model backend contract, provides the shared OpenAiCore implementation (payload building, tool building, HTTP request/response streaming, SSE parsing and tool-call normalization, and Debug formatting) for OpenAI-compatible chat-completions backends, and exposes Deepseek and Glm as direct child implementations that each wrap OpenAiCore with their own provider name, endpoint, model, and api_key.",
    "changeStatus": "modified"
  },
  "modified": [
    "openai.rs"
  ],
  "childModules": [
    {
      "path": "src/server/model/deepseek",
      "name": "deepseek",
      "purpose": "Implements the Deepseek streaming backend as a thin wrapper around the shared OpenAiCore (in src/server/model/openai.rs): constructs from a caller-supplied DeepseekConfig (endpoint/model/api_key) and delegates request/response streaming, payload building, SSE parsing, and Debug formatting to OpenAiCore with provider name \"Deepseek\"."
    },
    {
      "path": "src/server/model/glm",
      "name": "glm",
      "purpose": "Implements the GLM streaming backend as a thin wrapper around the shared OpenAiCore (in src/server/model/openai.rs): constructs from a caller-supplied GlmConfig (endpoint/model/api_key, defined in marix_common) and delegates request/response streaming, payload building, SSE parsing, and Debug formatting to OpenAiCore with provider name \"Glm\"."
    }
  ],
