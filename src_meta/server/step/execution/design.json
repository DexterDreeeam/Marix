  "module": {
    "path": "src/server/step/execution",
    "name": "execution",
    "purpose": "Owns server-side tracking of tool executions as a submodule of step. Execution captures one tool execution keyed by its ExecutionSignature, records the spawning step, accumulates ordered output chunks, and finalizes against the expected update count so out-of-order or early Succeed events still complete correctly. ExecutionHub holds a Mutex<HashMap<ExecutionSignature, Execution>>, spawns execution steps and emits ExecutionEvent::Evoke, routes Update/Succeed(count) events into the tracked Execution, emits StepEvent::Complete back to the step layer on completion, and reports per-signature status.",
    "changeStatus": "added"
  },
