{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs actor-based orchestration with complete, plan, or infeasible workflow decision parsing, ordered subintent execution, failure reanalysis, decision-first relay prompts with workflow tools prepended after duplicate and conflict validation, and streaming model execution.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Runs intent actors that render an IntentAnalyze decision prompt, parse complete, plan, or infeasible relay decisions, prevent direct steps once planning starts, snapshot and clear failed Plans before requesting a new verdict, and publish ordered subintent or terminal results."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Runs invocation actors, validates tools and JSON arguments, consumes typed ExecutionResult completions directly, assembles sequenced output, and publishes InvocationResult completions."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Defines the streaming-only model backend contract and exposes Deepseek, which validates complete SSE streams before logging one compact normalized OpenAI-compatible response, as a direct child implementation."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Stores the ordered subintent signatures owned by an intent."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Loads, validates, injects, and renders named prompt templates from the local template directory."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Builds model requests with the Relay decision/instruction prompt first, followed by ancestor-first intent context, a rendered System template based on the execution environment, workflow tools placed before execution tools after duplicate-name and workflow-name conflict validation, and serialized goal, subintent, plan-failure, and call context."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns session context, state, and runtime; SessionRuntime stores the concrete System received with executor tool previews and does not construct a replacement System."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Runs step actors, consumes typed InvocationResult completions directly, and aggregates ordered structured call results into StepResult."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns task actors and intent, step, invocation, and relay registries; resolves parent-indexed, ancestor-first intent context chains with plan-failure history, routes task events, and translates the root intent result into external task status."
    }
  ],
