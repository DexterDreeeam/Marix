{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs actor-based workflow orchestration with enum-mapped message and system prompts, parameter-driven system-template injection, and streaming model execution.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Runs intent actors, loads IntentAnalyze and ToolExecution message prompts by enum name, routes their mapped relays, parses verdict and StepDraft responses, and publishes IntentResult completions."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Runs invocation actors, validates tools and JSON arguments, consumes typed ExecutionResult completions directly, assembles sequenced output, and publishes InvocationResult completions."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Defines the streaming-only model backend contract and exposes Deepseek as a direct child implementation."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Runs plan actors, loads the PlanVerdict message prompt by enum name, consumes typed intent and relay results, reconstructs plans after failures, and publishes PlanResult completions."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Loads, injects, and renders named prompt templates, and maps crate-visible message prompt enums to System or System_Tools templates and relay names."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Runs relay actors, maps relay names to message and system prompts, derives tool needs from those mappings, and injects only parameters declared by each system template; System_Tools receives the tools marker."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns session context, state, and runtime; SessionRuntime stores the concrete System received with executor tool previews and does not construct a replacement System."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Runs step actors, consumes typed InvocationResult completions directly, and aggregates ordered structured call results into StepResult."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns Task actors, runtimes, and TaskAccess; TaskAccess keeps a weak session-context link, while TaskRuntime consumes the typed root IntentResult directly and maps it to the external TaskStatus."
    }
  ],
