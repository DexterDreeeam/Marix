{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs workflow orchestration through Arc-backed Task, Intent, Plan, Step, Invocation, and Relay implementations of the shared Actor and modern Runtime contracts; TaskAccess keeps type-inferred insertion and infers result types through five private StoredSignature mappings from signatures to actors, while five StoredActor implementations select task-scoped registries and reject duplicates; TaskRuntime holds those registries and the root intent, Task runs its current-thread executor on a dedicated thread, child actors spawn on that executor, and Session uses an inherent worker runtime.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Runs Arc-backed intent actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, content, step and plan tracking, and lifecycle, render IntentAnalyze prompts, create and register steps, plans, and relays through type-inferred TaskAccess insertion, and resolve child results from signatures that infer their mapped actor and result type."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Runs Arc-backed invocation actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, tool input, execution and output tracking, and lifecycle, assemble sequenced host output, and publish typed results to parent steps."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Owns synchronous and asynchronous model backend abstractions, response channels, requests, streaming responses, and backend errors."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Runs Arc-backed plan actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, child intents, failures, and lifecycle, advance children, render PlanVerdict prompts from the user request and plan failures, reconstruct plans, register child intents and relays through type-inferred TaskAccess insertion, and resolve results from signatures that infer their mapped actor and result type; the prompt context input remains unwired, so rendering can currently return an error."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Owns prompt loading and rendering: non-System templates receive the minimal shared System decision prefix, and parameter markers are sliced for deferred injection."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Runs Arc-backed relay actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, prompt, model and output state, and lifecycle, with an asynchronously prepared response receiver and custom loop that assembles typed model results."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns an inherent session worker runtime with public run, close, and dispatch operations that routes modern actor-backed tasks, host execution traffic, client TaskStatus transport, and tool context."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Runs Arc-backed step actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, draft, invocation tracking, and lifecycle, register invocations through type-inferred TaskAccess insertion, resolve invocation results from signatures that infer their mapped actor and result type, and publish aggregate completion."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns Arc-backed Task actors implementing the shared Actor and modern Runtime contracts; runtimes hold task access, actor registries, root intent, and lifecycle, asynchronously start and register root work through type-inferred TaskAccess insertion, route events, and translate external TaskStatus, while TaskAccess owns session transport, request data, shared registries, the current-thread executor, type-inferred insertion, and result lookup whose five private StoredSignature mappings infer Actor and Result types and whose five StoredActor implementations select registries and reject duplicate signatures."
    }
  ],
