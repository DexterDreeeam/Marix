{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs server orchestration with flattened step/tool content, prompt construction, and session lifecycle management.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Owns server-side invocation lifecycle and runtime routing between step events and host executor events."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Owns the server model backend abstraction. backend.rs defines the public ModelBackend trait, the crate-internal ModelBackendImpl trait, and a blanket impl that delegates request directly to ModelBackendImpl::request; backend_deepseek.rs implements DeepseekBackend as a config-driven streaming Deepseek chat-completions backend over reqwest with SSE parsing and a user-role single-message payload that preserves request.prompt as content; error.rs defines ModelBackendError with From conversions for io, serde_json, and reqwest errors plus a Display impl. mod.rs is namespace and re-export wiring only."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Owns server-side plan creation, step orchestration, and prompt-oriented rendering of flattened invocation input."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Owns regex-sliced prompt template loading, reusable module expansion, deferred parameter injection, and typed single-pass rendering."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Owns server-side model relay lifecycle, ordered output buffering, and source telemetry for model prompts and completed output."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns one generated session UUID, authenticated client/host workers, post-handshake correlation messages, task/executor routing, and disconnect cleanup."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Owns server-side step dispatch, flattened invocation input handling, and parameter-driven model prompt construction."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns task lifecycle, shared access to plans, steps, invocations, and relays, plus runtime dispatch across hierarchical protocol events."
    }
  ],
