{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs workflow orchestration through Arc-backed actors and runtimes; TaskAccess dynamically builds ordered context histories from runtime intent steps and plan failures, while IntentRuntime and PlanRuntime inject only context_chain and user_request into decision prompts.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Runs Arc-backed intent actors through shared Actor and Runtime contracts; runtimes dynamically build root-to-current context chains containing ordered step history, inject only context_chain and user_request into IntentAnalyze, and create steps, plans, and relays."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Runs Arc-backed invocation actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, tool input, execution and output tracking, and lifecycle, assemble sequenced host output, and publish typed results to parent steps."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Owns synchronous and asynchronous model backend abstractions, response channels, requests, streaming responses, and backend errors."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Runs Arc-backed plan actors through shared Actor and Runtime contracts; runtimes dynamically build root-to-current context chains containing accumulated failures, inject only context_chain and user_request into PlanVerdict, reconstruct plans, and create child intents and relays."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Owns prompt loading and rendering: non-System templates receive the shared System decision prefix, parameter markers are sliced for deferred injection, and decision prompts retain only user_request and context_chain with runtime history serialized inside the chain."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Runs Arc-backed relay actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, prompt, model and output state, and lifecycle, with an asynchronously prepared response receiver and custom loop that assembles typed model results."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns an inherent session worker runtime with public run, close, and dispatch operations that routes modern actor-backed tasks, host execution traffic, client TaskStatus transport, and tool context."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Runs Arc-backed step actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, draft, invocation tracking, and lifecycle, register invocations through type-inferred TaskAccess insertion, resolve invocation results from signatures that infer their mapped actor and result type, and publish aggregate completion."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns Arc-backed Task actors, runtimes, and TaskAccess; TaskAccess dynamically builds root-to-current context chains from runtime intent steps and plan failures, preserves their order, validates current plan membership, and retains session transport, registries, routing, execution, status translation, and live result lookup."
    }
  ],
