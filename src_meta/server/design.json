{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs actor-based orchestration with ordered execution, server-driven cursor continuation, successful and failed tool results published as accumulated summaries or No Summary, preserved cancellation reasons, failure reanalysis, streaming models, and task deadline and relay-budget guardrails.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Runs intent actors that request IntentAnalyze verdicts, dispatch complete, plan, and infeasible workflow decisions, prevent direct steps after planning starts, and publish ordered results."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Runs invocation actors, summarizes each successful or failed execution chunk, accumulates non-empty summaries, automatically requests the internal workflow_continuation while an approved cursor remains, and publishes the accumulated summary or No Summary; canceled invocations retain their cancellation reason."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Defines the streaming-only model backend contract, provides the shared OpenAiCore implementation (payload building, tool building, HTTP request/response streaming, SSE parsing and tool-call normalization, and Debug formatting) for OpenAI-compatible chat-completions backends, and exposes Deepseek and Glm as direct child implementations that each wrap OpenAiCore with their own provider name, endpoint, model, and api_key."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Stores the ordered subintent signatures owned by an intent."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Loads, validates, injects, and renders named prompt templates, including mandatory workflow_call_summary instructions and optional cursor-return guidance for tool-call summaries."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Runs model-backed Relay actors, renders system, workflow-policy, context, and mandatory tool-call-summary prompts, reserves WorkflowContinuation for internal server use, validates and serializes optional summary cursors, streams model responses, and resolves output by relay kind."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns session context, state, and runtime; accepts TaskRequest events, rejects task creation until a host and executor tools are available, logs registered tool counts and names at Info level, and delegates request normalization."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Runs step actors, checks the task completion deadline before creating each Step, and aggregates ordered structured invocation results into StepResult."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns task actors and registries, normalizes completion-time and relay-count limits, gates new Steps and Relays, runs the task deadline watchdog, cancels all task-owned Relay, Invocation, Step, and Intent actors, and translates root results into external task status."
    }
  ],
