{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs actor-based workflow orchestration with strict decision JSON; relay prompts order System, decision, and natural paired context messages, while model requests carry ordered prompts and Deepseek transports and logs compact raw JSON with streamed content accumulation.",
    "changeStatus": "modified"
  },
  "modified": [
    "."
  ],
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Runs intent actors through shared Actor and Runtime contracts; verdict relays render the IntentAnalyze decision prompt, identify the intent without a plan, and create steps, plans, or final results from strict verdict JSON."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Runs Arc-backed invocation actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, tool input, execution and output tracking, and lifecycle, assemble sequenced host output, and publish typed results to parent steps."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Owns synchronous and asynchronous model backends and streaming channels; ModelRequest carries a system message followed by ordered user prompts, while Deepseek emits compact raw request payloads, accumulates streamed content, and logs raw request and concatenated response records."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Runs plan actors through shared Actor and Runtime contracts; verdict relays identify the current plan so relay runtime can build accumulated plan context, then plans are reconstructed or finished with typed outcomes."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Loads, injects, and renders one named prompt template after all declared parameters are supplied; its template child owns partitioned decision instructions and the user_request-only System contract."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Runs relay actors, prompt construction, and streaming response assembly; RelayRuntime orders System, decision, then natural paired context messages, serializes calls with dynamic tool-name keys and plain failure text, and assembles sequenced model chunks without response tags."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns session context, state, and runtime; SessionContext keeps the sole WorkQueue<TaskSignature, Task> registry, snapshots expose TaskPreview values, and SessionRuntime creates and dispatches tasks through that registry."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Runs Arc-backed step actors through the shared Actor and modern Runtime contracts; runtimes own task access, signature, draft, invocation tracking, and lifecycle, register invocations through type-inferred TaskAccess insertion, resolve invocation results from signatures that infer their mapped actor and result type, and publish aggregate completion."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns Task actors, runtimes, and TaskAccess; Task exposes public previews, while TaskAccess holds a Weak SessionContext reference to avoid ownership cycles and provides task-local actor registries, result lookup, and session transport."
    }
  ],
