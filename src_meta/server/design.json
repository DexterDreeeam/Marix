{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs workflow orchestration through task-scoped actor registries and shared decision prompts: Intent and Plan runtimes inject only explicit request, intent, plan, and result data, while completion results propagate through owned actor boundaries.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Owns intent lifecycle orchestration and decision prompting: runtime renders System plus IntentAnalyze with user_request, intent, and ordered completed step_results before creating work or publishing a terminal result."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Owns task-registered invocation actors whose state carries lifecycle and ordered distinct-sequence output, while runtimes drive host execution and publish terminal results whose sequence count is derived uniformly from received output."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Owns synchronous and asynchronous model backend abstractions, response channels, requests, streaming responses, and backend errors."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Owns sequential child-intent execution and reconstruction: runtime records each failure before rendering System plus PlanVerdict with user_request, parent_intent, current_plan, and plan_failures, then installs a replacement without recording that failure twice."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Owns prompt loading and rendering: non-System templates receive the minimal shared System decision prefix, and parameter markers are sliced for deferred injection."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Owns task-registered relay actors whose state carries model access, lifecycle, and ordered output, while runtimes stream model responses and publish result-carrying completion updates to intents."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns server session routing, authenticated Host initialization, root intent construction with no parent plan, and nested workflow event delivery."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Owns task-registered invocation groups: Step preserves the validated draft, runtime creates and registers every invocation before starting them directly, and terminal updates trigger aggregate completion."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns task-scoped actor registries and routing: TaskAccess exposes immutable intent content alongside intent and invocation results, while TaskRuntime routes actor events and explicitly starts registered intents."
    }
  ],
