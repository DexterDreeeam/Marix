{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs workflow orchestration through private task-scoped actor registries: TaskAccess exposes intent and relay result lookups, task routing starts registered intents, and intent and plan states retain task access plus local lifecycle state.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Owns intent lifecycle orchestration: state retains task access, child steps, an optional plan, status, and event channels, while runtime reads relay results through TaskAccess, creates steps or plans, and publishes terminal results."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Owns host execution creation, ordered output aggregation, terminal status handling, and direct task routing to its step."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Owns synchronous and asynchronous model backend abstractions, response channels, requests, streaming responses, and backend errors."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Owns sequential child-intent execution and reconstruction: state stores current intent signatures, accumulated failure history, status, and event channels, while runtime reads results through TaskAccess, starts the first incomplete intent, evaluates failures through a relay, replaces reconstructed intent sets, and finishes directly on success or infeasibility."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Owns regex-sliced prompt template loading, reusable module expansion, deferred parameter injection, and typed single-pass rendering."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Owns asynchronous model relay execution, ordered output aggregation, terminal status handling, and direct task routing to its intent."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns server session routing, authenticated Host initialization, root intent construction with no parent plan, and nested workflow event delivery."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Owns invocation-group execution, ignores nonterminal updates, validates registered terminal results, aggregates outputs, and routes completion directly to its intent."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns task-scoped actor registries and routing: TaskAccess keeps registries private and exposes intent and relay result lookups, while TaskRuntime routes actor events and starts registered intents on IntentStart."
    }
  ],
