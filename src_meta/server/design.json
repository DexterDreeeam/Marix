{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Runs workflow orchestration through task-scoped actor registries: access exposes intent and invocation result lookups, task routing starts registered children, and result-carrying completion updates propagate through plans, steps, invocations, and relays.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/server/intent",
      "name": "intent",
      "purpose": "Owns intent lifecycle orchestration: runtime consumes relay completion payloads directly, creates steps or plans, and publishes terminal results, while state retains task access and local child lifecycle data."
    },
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Owns task-registered invocation actors whose state carries lifecycle and ordered execution output, while runtimes drive host execution and publish result-carrying completion updates to steps."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Owns synchronous and asynchronous model backend abstractions, response channels, requests, streaming responses, and backend errors."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Owns sequential child-intent execution and reconstruction: runtime reads child intent results through TaskAccess, consumes relay completion payloads directly, replaces reconstructed intent sets, and publishes terminal plan results."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Owns regex-sliced prompt template loading, reusable module expansion, deferred parameter injection, and typed single-pass rendering."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Owns task-registered relay actors whose state carries model access, lifecycle, and ordered output, while runtimes stream model responses and publish result-carrying completion updates to intents."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns server session routing, authenticated Host initialization, root intent construction with no parent plan, and nested workflow event delivery."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Owns task-registered invocation-signature groups: runtime starts invocations through TaskEvent, reads terminal results through TaskAccess, aggregates outputs, and routes completion to the intent."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns task-scoped actor registries and routing: TaskAccess exposes intent and invocation result lookups, while TaskRuntime routes events and explicitly starts registered intents and invocations."
    }
  ],
