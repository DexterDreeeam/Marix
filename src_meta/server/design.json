{
  "schemaVersion": 1,
  "module": {
    "path": "src/server",
    "name": "server",
    "purpose": "Server crate namespace for model, session, task, prompt, step, invocation, relay, and plan runtime subjects. Invocation and Relay are top-level server subjects while protocol shapes live in marix-protocol.",
    "changeStatus": "modified"
  },
  "modified": [
    "main.rs",
    "lib.rs"
  ],
  "childModules": [
    {
      "path": "src/server/invocation",
      "name": "invocation",
      "purpose": "Owns the server-side Invocation subject and InvocationHub storage boundary for invocation tracking; behavior is intentionally left as design stubs in this interface pass."
    },
    {
      "path": "src/server/model",
      "name": "model",
      "purpose": "Owns the server model backend abstraction. backend.rs defines the public ModelBackend trait, the crate-internal ModelBackendImpl trait, and a blanket impl that delegates request directly to ModelBackendImpl::request; backend_deepseek.rs implements DeepseekBackend as a config-driven streaming Deepseek chat-completions backend over reqwest with SSE parsing and a user-role single-message payload that preserves request.prompt as content; error.rs defines ModelBackendError with From conversions for io, serde_json, and reqwest errors plus a Display impl. mod.rs is namespace and re-export wiring only."
    },
    {
      "path": "src/server/plan",
      "name": "plan",
      "purpose": "Owns server-side plan runtime orchestration and plan stringification over Invocation step kinds."
    },
    {
      "path": "src/server/prompt",
      "name": "prompt",
      "purpose": "Defines the server prompt interface, render_template conditional/variable rendering, InitialPrompt for initial planning, and AnalysisPrompt for model analysis of completed execution output using RequestBrief, ExecutionOutput, CurrentPlan, PendingIntentions, and Tools variables."
    },
    {
      "path": "src/server/relay",
      "name": "relay",
      "purpose": "Owns the server-side Relay subject and RelayHub storage boundary for relay tracking; relay behavior remains intentionally unimplemented."
    },
    {
      "path": "src/server/session",
      "name": "session",
      "purpose": "Owns server session startup and routing boundaries for client, host, and task channels; implementation routing still awaits the new hierarchical event shape."
    },
    {
      "path": "src/server/step",
      "name": "step",
      "purpose": "Owns the server runtime Step type and re-exports top-level Invocation and Relay subjects for callers that still enter through the step namespace."
    },
    {
      "path": "src/server/task",
      "name": "task",
      "purpose": "Owns server task runtime and TaskState. TaskState holds InvocationHub, RelayHub, PlanHub, and step storage while implementation event routing remains deferred."
    }
  ],
