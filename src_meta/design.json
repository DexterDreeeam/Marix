{
  "schemaVersion": 1,
  "module": {
    "path": "src",
    "name": "src",
    "purpose": "Defines the Marix Rust workspace and its client, host, server, telemetry, protocol, common, and tool packages.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/client",
      "name": "client",
      "purpose": "Owns Client session transport, user-facing task result output, and remote-first telemetry with file fallback."
    },
    {
      "path": "src/common",
      "name": "common",
      "purpose": "Owns shared configuration, logging, external wrappers, the Actor and modern Runtime lifecycle contracts, signature contracts, authenticated channels, and insertion-ordered work queues."
    },
    {
      "path": "src/host",
      "name": "host",
      "purpose": "Owns Host connectivity, inherent execution and executor worker runtimes, task-level invocation updates, and tool registration."
    },
    {
      "path": "src/protocol",
      "name": "protocol",
      "purpose": "Defines serialized workflow contracts whose signatures implement the shared common Signature contract, with shared common ActorStatus workflow updates, dedicated host execution statuses, and external TaskStatus transport."
    },
    {
      "path": "src/server",
      "name": "server",
      "purpose": "Runs workflow orchestration through Arc-backed Task, Intent, Plan, Step, Invocation, and Relay implementations of the shared Actor and modern Runtime contracts; TaskRuntime holds task-scoped registries, access, and the root intent, Task launches its current-thread executor on a dedicated thread, child actors spawn on that executor, and Session uses an inherent worker runtime."
    },
    {
      "path": "src/server_telemetry",
      "name": "server_telemetry",
      "purpose": "Runs the standalone telemetry collector and its paginated HTTP API while serving browser assets from the static http folder."
    },
    {
      "path": "src/tool",
      "name": "tool",
      "purpose": "Top-level marix-tool crate defining ToolProgram and six feature-gated native tools with shared compatibility parsing for Windows path and cwd backslashes."
    }
  ],
