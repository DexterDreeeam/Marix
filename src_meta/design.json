{
  "schemaVersion": 1,
  "module": {
    "path": "src",
    "name": "src",
    "purpose": "Workspace source root for Marix Rust crates and prompt sources; direct child modules are crate packages for protocol, common, server, client, host, tool, and prompts.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/client",
      "name": "client",
      "purpose": "Owns the client library and CLI-facing session API, including resilient server reconnects, task create/cancel messages, and conversion of task status updates into ClientEvent output."
    },
    {
      "path": "src/common",
      "name": "common",
      "purpose": "Shared common crate root for configuration, local-or-remote telemetry, authenticated wildcard-listener channels, reusable structures, and external adapters."
    },
    {
      "path": "src/host",
      "name": "host",
      "purpose": "Owns host session connectivity and host-side executor/execution routing between server events and registered tools."
    },
    {
      "path": "src/prompt",
      "name": "prompt",
      "purpose": "Owns prompt templates used by model-facing steps, including raw strict JSON response requirements, no-Markdown-fence output constraints, single-string tool and model input guidance, flat model-facing PlanDraft step objects, and answer-only Initial and Analysis JSON for requests that are already answerable."
    },
    {
      "path": "src/protocol",
      "name": "protocol",
      "purpose": "Owns the hierarchical protocol contracts for sessions, tasks, plans, steps, invocations, relays, executors, host executions, tools, signatures, statuses, and errors."
    },
    {
      "path": "src/server",
      "name": "server",
      "purpose": "Owns server session routing and task/plan/step orchestration, including model relays, host invocations, prompt construction, and hierarchical protocol event flow."
    },
    {
      "path": "src/target",
      "name": "target",
      "purpose": "Owns the target source module."
    },
    {
      "path": "src/tool",
      "name": "tool",
      "purpose": "Top-level marix-tool crate (lib marix_tool) that defines the per-tool ToolProgram interface and compiles one executable per native tool program. Cargo.toml now depends on marix-protocol, and ToolProgram uses marix_protocol::ToolPreview."
    }
  ],
