{
  "schemaVersion": 1,
  "module": {
    "path": "src",
    "name": "src",
    "purpose": "Defines the Marix Rust workspace and its client, host, server, source-aware telemetry, protocol, common, and tool packages.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/client",
      "name": "client",
      "purpose": "Owns the client API and CLI session transport, installing optional SessionId correlation metadata while preserving immediate channel readiness."
    },
    {
      "path": "src/common",
      "name": "common",
      "purpose": "Owns shared configuration, third-party wrappers, source- and session-aware telemetry with persistent migration/query support, and reusable transport structures."
    },
    {
      "path": "src/host",
      "name": "host",
      "purpose": "Owns host execution and its resilient server session, configuring host-sourced telemetry without gating channel readiness."
    },
    {
      "path": "src/protocol",
      "name": "protocol",
      "purpose": "Owns the hierarchical protocol contracts for sessions, tasks, plans, steps, invocations, relays, executors, host executions, tools, signatures, statuses, and errors."
    },
    {
      "path": "src/server",
      "name": "server",
      "purpose": "Runs the server core with server-sourced telemetry and owns task, session, model, prompt, step, and ordered relay orchestration."
    },
    {
      "path": "src/tool",
      "name": "tool",
      "purpose": "Top-level marix-tool crate defining ToolProgram and six feature-gated native tool executables, including the OsEnv system-environment tool."
    },
    {
      "path": "src/server_telemetry",
      "name": "server_telemetry",
      "purpose": "Runs the standalone telemetry collector and its self-hosted HTTP log viewer."
    }
  ],
