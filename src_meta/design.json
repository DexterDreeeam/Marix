{
  "schemaVersion": 1,
  "module": {
    "path": "src",
    "name": "src",
    "purpose": "Defines the Marix Rust workspace and its client, host, server, telemetry, protocol, common, and tool packages, including level-aware telemetry and fifteen native tool binaries.",
    "changeStatus": "modified"
  },
  "modified": ["."],
  "childModules": [
    {
      "path": "src/client",
      "name": "client",
      "purpose": "Owns Client session transport, connection state, task submission through ClientSession::create_task with request, optional completion-time, and optional relay-count arguments, and delivery of task results and connection failures."
    },
    {
      "path": "src/common",
      "name": "common",
      "purpose": "Owns shared configuration, level-based telemetry logging with threshold queries, executable-sibling standalone tool logging, approved external wrappers including Tokio timers, generic Actor and Runtime contracts, signatures, authenticated channels, and insertion-ordered work queues."
    },
    {
      "path": "src/host",
      "name": "host",
      "purpose": "Owns Host connectivity, Arc-backed per-execution actor runtimes, executor workers, tool registration, typed execution results, and unknown-tool failure delivery."
    },
    {
      "path": "src/protocol",
      "name": "protocol",
      "purpose": "Defines serialized task requests with optional completion-time and relay-count guardrails, context chains, relay, step, invocation, execution, session, tool, and workflow contracts."
    },
    {
      "path": "src/server",
      "name": "server",
      "purpose": "Runs actor-based orchestration with workflow decision parsing, ordered execution, failure reanalysis, streaming models, task deadline and relay-budget guardrails, task-owned cancellation, and Info-level executor tool registration logging."
    },
    {
      "path": "src/server_telemetry",
      "name": "server_telemetry",
      "purpose": "Runs the standalone telemetry collector and paginated HTTP API with minimum LogLevel threshold and tag filtering plus a distinct-tags listing endpoint, and serves static browser assets for level-and-tag-aware log browsing."
    },
    {
      "path": "src/tool",
      "name": "tool",
      "purpose": "Defines ToolProgram and fifteen feature-gated native tool binaries whose previews describe host compatibility and whose normal execution reads one JSON payload, logs the input and output beside the executable, and writes only the JSON result to standard output."
    }
  ],
