{
  "schemaVersion": 1,
  "module": {
    "path": "src",
    "name": "src",
    "purpose": "Workspace source root for Marix Rust crates and prompt sources; direct child modules are crate packages for protocol, common, server, client, host, tool, and prompts.",
    "changeStatus": "modified"
  },
  "modified": [
    "."
  ],
  "childModules": [
    {
      "path": "src/client",
      "name": "client",
      "purpose": "Client crate namespace for the marix_client library and client binaries. ClientEvent carries Common streaming output and Done completion events by signature id, and ClientSession connects to the server over the client channel selected by ChannelEndpoint::Client, creates tasks with an empty TaskSignature.name, and keeps the user request only in TaskEvent::Create."
    },
    {
      "path": "src/common",
      "name": "common",
      "purpose": "Shared common crate root for reusable config loading with default CoreConfig fallback, server IP and handshake token resolution from plain config values, external re-export adapters, database telemetry logging, and structure utilities. It exposes WorkQueue cleanup support used by server host-disconnect session reset, and lib.rs re-exports serializable config system types Arch, Platform, and System alongside Config, ServerConfig, and related models, plus the Logger telemetry client with LogMessage, LogTag, and LoggingError."
    },
    {
      "path": "src/host",
      "name": "host",
      "purpose": "Host crate namespace for HostSession and host-side executor dispatch/runtime exported through the executor module."
    },
    {
      "path": "src/prompt",
      "name": "prompt",
      "purpose": "Owns prompt templates used by model-facing steps, including raw strict JSON response requirements, no-Markdown-fence output constraints, single-string tool and model input guidance, flat model-facing PlanDraft step objects, and answer-only Initial and Analysis JSON for requests that are already answerable."
    },
    {
      "path": "src/protocol",
      "name": "protocol",
      "purpose": "Owns marix-protocol crate definitions and namespace exports for hierarchical session, task, plan, step, invocation, executor, relay, host execution, tool, and shared signature/status/error contracts."
    },
    {
      "path": "src/server",
      "name": "server",
      "purpose": "Server crate namespace for model, session, task, prompt, step, invocation, relay, and plan runtime subjects. Invocation and Relay are top-level server subjects while protocol shapes live in marix-protocol."
    },
    {
      "path": "src/target",
      "name": "target",
      "purpose": "Owns the target source module."
    },
    {
      "path": "src/tool",
      "name": "tool",
      "purpose": "Top-level marix-tool crate (lib marix_tool) that defines the per-tool ToolProgram interface and compiles one executable per native tool program. Cargo.toml now depends on marix-protocol, and ToolProgram uses marix_protocol::ToolPreview."
    }
  ],
