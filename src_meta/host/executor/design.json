{
  "schemaVersion": 1,
  "module": {
    "path": "src/host/executor",
    "name": "executor",
    "purpose": "Owns host-side tool registry, tool process launching, and execution orchestration. Executor sends preview responses through send_preview_event, reports unknown-tool failures through send_failed_event, and includes System::new host metadata with current ToolPreview entries for the server session.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/host/executor/execution",
      "name": "execution",
      "purpose": "Per-execution host runtime split out of executor.rs: ExecutionRuntime drives one server Execution, spawning a worker in new that reads raw tool input from parameters.input.content on the typed ExecutionRequest, runs tool.execute, and sends a seq-stamped ExecutionUpdate plus a terminal ExecutionStatus::Succeed carrying the expected update count while handling Cancel/Kill control events; ExecutionState holds the host-local Tool handle, ExecutionRequest, and server SessionMessage sender."
    }
  ],
