{
  "schemaVersion": 1,
  "module": {
    "path": "src/host",
    "name": "host",
    "purpose": "Owns Host connectivity (a single-attempt, bounded-timeout connect to Server and Telemetry that exits the process on failure or on later disconnection rather than retrying), per-execution actor runtimes, executor workers, and the ExecutorState-held ExecutorCache: a consuming 10-entry FIFO where try_cache returns content at or below its 24 KiB threshold whole, otherwise returns a UTF-8-safe 16 KiB chunk and caches the remainder, and pick consumes an entry then reuses try_cache.",
    "changeStatus": "modified"
  },
  "modified": ["main.rs", "session.rs"],
  "childModules": [
    {
      "path": "src/host/execution",
      "name": "execution",
      "purpose": "Runs each tool execution on its own OS thread with a current-thread Tokio runtime, applies ExecutorCache::try_cache so outputs at or below 24 KiB return whole while larger outputs return a first UTF-8-safe 16 KiB chunk with a continuation cursor, publishes typed ExecutionResult statuses, and defers cancellation until a blocking tool call returns."
    },
    {
      "path": "src/host/executor",
      "name": "executor",
      "purpose": "Owns host executor workers and the ExecutorState-held ExecutorCache: a consuming 10-entry FIFO configured by CHUNK_BYTES (16 KiB), CACHE_THRESHOLD_BYTES (24 KiB), and CACHE_CAPACITY (10); try_cache returns content at or below 24 KiB whole, otherwise returns a UTF-8-safe 16 KiB chunk and caches the remainder, and pick consumes an entry then reuses try_cache. It also loads compatible tools, routes regular executions, intercepts workflow_continuation requests, and publishes plain content with continuation cursors."
    }
  ],
