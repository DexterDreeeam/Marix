{
  "schemaVersion": 1,
  "module": {
    "path": "src/host",
    "name": "host",
    "purpose": "Owns Host connectivity, Arc-backed per-execution actor runtimes, executor workers, tool registration, typed execution results, and unknown-tool failure delivery.",
    "changeStatus": "unchanged"
  },
  "childModules": [
    {
      "path": "src/host/execution",
      "name": "execution",
      "purpose": "Runs each tool execution on its own OS thread with a current-thread Tokio runtime, stores an Arc<ExecutionRuntime> in the actor, publishes typed ExecutionResult statuses, and defers cancellation handling until a blocking tool call returns."
    },
    {
      "path": "src/host/executor",
      "name": "executor",
      "purpose": "Owns the host executor worker, routes executions and tool queries, and reports an unknown tool as ActorStatus::Complete with a failed ExecutionResult."
    }
  ],
