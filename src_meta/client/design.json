    {
      "path": "src/client/app",
      "name": "app",
      "purpose": "Contains the placeholder marix-client-app binary entrypoint reserved for the client application layout."
    },
    {
      "path": "src/client/cli",
      "name": "cli",
      "purpose": "Contains the marix-client-cli command-line binary entrypoint. The CLI accepts exactly --interactive or --oneshot \"request\", drains signature-aware ClientEvent output, prints Common messages and optional Done messages, and exits oneshot on Done completion. It connects the telemetry Logger over the authenticated channel transport before starting the ClientSession."
    }
