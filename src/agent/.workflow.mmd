flowchart LR
  %% lib.rs only wires child modules and re-exports public agent interfaces. main.rs is the marix-agent binary entry that loads the global Config and, unless config.agent.enabled is false, runs Session::new(config.name) and parks the process.
  subgraph main_rs[main.rs marix-agent bin]
    MarixAgentBin["marix-agent\nbin entry: Config + Session"]
  end

  subgraph agent_config[common config]
    Config["Config"]
  end

  subgraph session_module[session module]
    Session["Session\nstruct"]
    SessionContext["SessionContext\nstruct"]
  end

  subgraph task_module[task module]
    Task["Task\nstruct"]
    Step["Step\nstruct"]
    Execution["Execution\nstruct"]
  end

  subgraph model_module[model module]
    ModelBackend["ModelBackend\ntrait"]
    DeepseekBackend["DeepseekBackend\nstruct"]
    ModelRequest["ModelRequest\nstruct"]
    ModelResponse["ModelResponse\nenum"]
    ModelBackendError["ModelBackendError\nenum"]
  end

  subgraph common_interfaces[common interfaces]
    SessionMessage["SessionMessage\n(between-session envelope)"]
    SessionEvent["SessionEvent"]
    TaskId["TaskId"]
    WorkQueue["WorkQueue"]
  end

  MarixAgentBin -->|"loads / exits on error"| Config
  MarixAgentBin -->|"if config.agent.enabled runs Session::new(config.name)"| Session
  Session -->|"owns Arc context and workers"| SessionContext
  SessionContext -->|"client/host channel endpoints carry"| SessionMessage
  SessionMessage -->|"wraps event"| SessionEvent
  SessionContext -->|"tasks: WorkQueue<TaskId, Task>"| WorkQueue
  SessionContext -->|"task key"| TaskId
  SessionContext -->|"creates and routes events to"| Task
  Task -->|"raises Step values"| Step
  Task -->|"optional model_backend"| ModelBackend
  Task -->|"execution queue entries"| Execution
  ModelBackend -->|"request payload"| ModelRequest
  ModelBackend -->|"response channel yields"| ModelResponse
  DeepseekBackend -->|"implements via private backend impl"| ModelBackend
  ModelBackend -->|"fails with"| ModelBackendError
