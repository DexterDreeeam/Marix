  subgraph session_rs[session.rs]
    Session["Session\nstruct"]
  end

  subgraph session_context_rs[session_context.rs]
    SessionContext["SessionContext\nstruct"]
    Tasks["tasks\nWorkQueue<TaskId, Task>"]
    ClientChannel["client_tx/client_rx\nSessionEvent channels"]
    HostChannel["host_tx/host_rx\nSessionEvent channels"]
  end

  subgraph task_module[task module]
    Task["Task\nstruct"]
  end

  subgraph common_protocol[common protocol]
    SessionEvent["SessionEvent"]
    TaskSessionEvent["TaskSessionEvent"]
    ExecutionSessionEvent["ExecutionSessionEvent"]
