  Session -->|"Arc<SessionContext>"| SessionContext
  Session -->|"accepts client remoc channel"| ClientChannel
  Session -->|"accepts host remoc channel"| HostChannel
  ClientChannel -->|"client SessionEvent stream"| SessionContext
  HostChannel -->|"host SessionEvent stream"| SessionContext
  SessionContext -->|"creates and runs"| Task
  SessionContext -->|"stores by TaskId"| Tasks
  SessionContext -->|"routes TaskSessionEvent"| TaskSessionEvent
  SessionContext -->|"routes ExecutionSessionEvent"| ExecutionSessionEvent
  TaskSessionEvent -->|"wrapped by"| SessionEvent
  ExecutionSessionEvent -->|"wrapped by"| SessionEvent
  SessionContext -->|"sends routed SessionEvent via task sender"| Task
