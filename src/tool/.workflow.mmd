flowchart LR
  %% marix-tool crate: ToolProgram interface plus one executable per native tool selected via Cargo features; the Executor-side Tool handle now lives in the host crate.
  subgraph tool_program_rs[tool_program.rs]
    ToolProgram["ToolProgram\ntrait"]
  end

  subgraph tool_main_rs[tool_main.rs bin entry]
    BinEntry["main -> run<T: ToolProgram>\n--preview/--run JSON driver"]
  end

  subgraph native_mod[native module]
    NativeTools["native tool programs\nReadFile/WriteFile/ListDirectory/SearchText/ShellExecute"]
    SelectedTool["SelectedTool\ncfg-selected active tool"]
  end

  subgraph common_protocol[marix_common protocol]
    ToolPreview["ToolPreview"]
  end

  NativeTools -->|"implement"| ToolProgram
  NativeTools -->|"cfg feature re-exports as"| SelectedTool
  BinEntry -->|"run(SelectedTool)"| SelectedTool
  BinEntry -->|"--preview prints preview()"| ToolProgram
  BinEntry -->|"--run <input> calls invoke()"| ToolProgram
  ToolProgram -->|"preview() returns"| ToolPreview
