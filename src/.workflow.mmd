    ToolExecutionResult["ToolExecutionResult<T>\nComplete or Cancelled"]
    NativeTools["native Tool implementations"]
  end
  subgraph agent_runtime["agent"]
    Session["Session\nfrontdoor endpoint"]
    Task["Task\nfrontdoor endpoint"]
