  %% HostSession now connects to the agent's configured host bind address (spawn_worker -> connect_channel), owns a single per-connection Executor built by Executor::new(agent_tx), and pumps inbound SessionEvents through run_worker -> Executor::route_session_event over a current-thread tokio runtime; close signals the shutdown flag and joins the worker. The executor is a single route_session_event router (intercepts Evoke into create_execution to spawn+track an ExecutionRuntime, and forwards other execution events to the target ExecutionRuntime via executions.with), while the execution runtime and ToolRegistry are implemented. Executor::new(agent_tx) stores the shared agent SessionEvent sender and builds a ToolRegistry that reads the global Config and loads Tool handles from the configured tool directory.
  subgraph session_rs[session.rs]
    HostSession["HostSession\nstruct"]
  end

  subgraph executor_mod[executor module]
