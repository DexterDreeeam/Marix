flowchart LR
  %% HostSession and Executor method bodies remain panic-backed stubs; the executor execution runtime is implemented.
  subgraph session_rs[session.rs]
    HostSession["HostSession\nstruct"]
  end

  subgraph executor_mod[executor module]
    Executor["Executor\nstruct"]
    ExecutionRuntime["ExecutionRuntime\nstruct"]
    ExecutionContext["ExecutionContext\nstruct"]
  end

  subgraph tool_crate[tool crate marix-host-tool]
    Tool["Tool\nexecutable handle"]
    ToolProgram["ToolProgram\ntrait + native tool bins"]
  end

  subgraph common_protocol[common protocol]
    SessionEvent["SessionEvent"]
    ExeId["ExeId"]
    ExecutionRequest["ExecutionRequest"]
    ExecutionStatus["ExecutionStatus"]
    ExecutionUpdate["ExecutionUpdate"]
    ExecutionSignature["ExecutionSignature"]
    ToolPreview["ToolPreview"]
  end

  HostSession -->|"agent_tx/agent_rx endpoints"| SessionEvent
  HostSession -->|"owns executor"| Executor
  Executor -->|"executions WorkQueue keyed by"| ExeId
  Executor -->|"tracks"| ExecutionRuntime
  ExecutionRuntime -->|"owns Arc"| ExecutionContext
  ExecutionContext -->|"parameters.signature"| ExecutionSignature
  ExecutionContext -->|"agent_tx forwards"| SessionEvent
  Executor -->|"preview advertises"| ToolPreview
  Executor -->|"evoke request"| ExecutionRequest
  Executor -->|"evoke/query/cancel/kill return"| ExecutionStatus
  Executor -->|"updates receiver emits"| ExecutionUpdate
  ExecutionContext -->|"holds Tool handle from marix-host-tool"| Tool
  Tool -->|"spawns --preview/--run binaries built by"| ToolProgram
  ToolProgram -->|"preview() returns"| ToolPreview
