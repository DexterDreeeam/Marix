  end

  subgraph work_queue_rs[work_queue.rs]
    WorkQueue["WorkQueue<K, V>\nstruct"]
    WorkingMap["working\nArc<Mutex<BTreeMap<K, V>>>"]
    CompleteMap["complete\nArc<Mutex<BTreeMap<K, V>>>"]
  end

  ChannelFns -->|"build_channel() returns local pair"| LocalAliases
  ChannelFns -->|"accept/connect bootstrap rch::mpsc over base handshake"| NetAliases
  NetAliases -->|"wrapped in std::sync::Mutex as"| SharedAliases
  ChannelFns -->|"fails with"| ChannelError
  WorkQueue -->|"owns in-progress entries"| WorkingMap
  WorkQueue -->|"owns completed entries"| CompleteMap
  WorkQueue -->|"complete(key) moves working entry"| CompleteMap
